Complex[n::Num'r] := n, n

;ns Complex[n::Num'r] ::Num ::Txt'rep
	
	from = { real :n -> Complex[n] | Complex real 0 }

;; https://mathworld.wolfram.com/ComplexExponentiation.html

;; quaternions
Complex4[n::Num'r] := n, n, n, n
;ns Complex4 [n::Num'r] ::Num ::Txt'rep

;; octonions
Complex8[n::Num'r] := n, n, n, n, n, n, n, n
;ns Complex8[n::Num'r] ::Num ::Txt'rep
